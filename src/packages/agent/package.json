{
	"name": "@auto-ml-skills/disco-agent-core",
	"version": "0.0.3",
	"description": "General-purpose agent with transport abstraction, state management, and attachment support",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./node": {
			"types": "./dist/node.d.ts",
			"import": "./dist/node.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsgo -p tsconfig.build.json",
		"test": "vitest --run --passWithNoTests",
		"test:harness": "vitest --run --passWithNoTests",
		"coverage:harness": "vitest --run --passWithNoTests --coverage",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"dependencies": {
		"@auto-ml-skills/disco-ai": "^0.0.3",
		"ignore": "7.0.5",
		"typebox": "1.1.38",
		"yaml": "2.9.0"
	},
	"keywords": [
		"ai",
		"agent",
		"llm",
		"transport",
		"state-management"
	],
	"author": "Auto-ML-Skills",
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/VectorSpaceLab/Auto-ML-Skills.git",
		"directory": "packages/agent"
	},
	"engines": {
		"node": ">=22.19.0"
	},
	"devDependencies": {
		"@types/node": "24.12.4",
		"@vitest/coverage-v8": "4.1.9",
		"typescript": "5.9.3",
		"vitest": "4.1.9"
	}
}
