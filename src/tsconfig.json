{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"noEmit": true,
		"paths": {
			"*": ["./*"],
			"@auto-ml-skills/disco-ai": ["./packages/ai/src/index.ts"],
			"@auto-ml-skills/disco-ai/oauth": ["./packages/ai/src/oauth.ts"],
			"@auto-ml-skills/disco-ai/*": ["./packages/ai/src/*.ts", "./packages/ai/src/providers/*.ts"],
			"@auto-ml-skills/disco-ai/dist/*": ["./packages/ai/src/*"],
			"@auto-ml-skills/disco-agent-core": ["./packages/agent/src/index.ts"],
			"@auto-ml-skills/disco-agent-core/*": ["./packages/agent/src/*"],
			"@auto-ml-skills/disco": ["./packages/coding-agent/src/index.ts"],
			"@auto-ml-skills/disco/hooks": ["./packages/coding-agent/src/core/hooks/index.ts"],
			"@auto-ml-skills/disco/*": ["./packages/coding-agent/src/*"],
			"typebox": ["./node_modules/typebox"],
			"@auto-ml-skills/disco-tui": ["./packages/tui/src/index.ts"],
			"@auto-ml-skills/disco-tui/*": ["./packages/tui/src/*"]
		}
	},
	"include": ["packages/*/src/**/*"],
	"exclude": ["**/dist/**"]
}
